{
  "datasets": [
    {
      "name": "6a7641c2",
      "displayName": "Recent Monthly Financial Aggregates",
      "queryLines": [
        "SELECT sum(Amount) FROM workspace.default.financialssilver\r\n",
        "WHERE Date >= current_date() - INTERVAL 30 DAY;"
      ]
    },
    {
      "name": "acaae497",
      "displayName": "Thirty Day Spend Totals by Financial Category",
      "queryLines": [
        "SELECT Category,\r\n",
        "       SUM(Amount) as total_spend\r\n",
        "FROM workspace.default.financialssilver\r\n",
        "WHERE Date >= current_date() - INTERVAL 30 DAY\r\n",
        "GROUP BY Category;"
      ]
    },
    {
      "name": "18e1a64c",
      "displayName": "Category Wise Spending and Transaction Summary",
      "queryLines": [
        "SELECT \r\n",
        "  category,\r\n",
        "  SUM(Amount) AS total_spend,\r\n",
        "  COUNT(*) AS transactions\r\n",
        "FROM workspace.default.financialssilver\r\n",
        "GROUP BY category\r\n",
        "ORDER BY total_spend DESC;"
      ]
    },
    {
      "name": "561e60fc",
      "displayName": "Last Thirty Day Card Spend Analysis",
      "queryLines": [
        "SELECT Card,\r\n",
        "       SUM(Amount) as total_spend\r\n",
        "FROM workspace.default.financialssilver\r\n",
        "WHERE Date >= current_date() - INTERVAL 30 DAY\r\n",
        "GROUP BY Card;"
      ]
    },
    {
      "name": "7e9980c3",
      "displayName": "Monthly Financial Summary by Year",
      "queryLines": [
        "SELECT\r\n",
        "    MONTH(Date) AS MonthNumber,\r\n",
        "    YEAR(Date) AS YearNumber,\r\n",
        "    SUM(Amount) AS TotalValue\r\n",
        "FROM\r\n",
        "    workspace.default.financialssilver\r\n",
        "GROUP BY\r\n",
        "    MONTH(Date),\r\n",
        "    YEAR(Date)\r\n",
        "ORDER BY\r\n",
        "    YearNumber,\r\n",
        "    MonthNumber;"
      ]
    }
  ],
